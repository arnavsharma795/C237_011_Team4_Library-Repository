<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Book - RP Library</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">📚 RP Library System </a>

        <div class="ms-auto">
            <a href="/inventory" class="btn btn-outline-light me-2">
                Inventory
            </a>
            <a href="/logout" class="btn btn-outline-light">
                Logout
            </a>
        </div>
    </div>
</nav>

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">
                Add New Book
            </h3>
        </div>

        <div class="card-body">
            <form action="/addBook" method="POST">
                <div class="mb-3">
                    <label class="form-label">
                        Book Title
                    </label>
                    <input type="text" name="title" class="form-control" placeholder="Enter book title" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        Author
                    </label>
                    <input  type="text" name="author" class="form-control" placeholder="Enter author name" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        Genre
                    </label>
                    <select name="genre" class="form-control" required>
                        <option value="">Select Genre</option>
                        <option value="Fantasy">Fantasy</option>
                        <option value="Science">Science</option>
                        <option value="Romance">Romance</option>
                        <option value="Adventure">Adventure</option>
                        <option value="Horror">Horror</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        Description
                    </label>
                    <textarea name="description" class="form-control" rows="4" placeholder="Enter book description"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        Quantity
                    </label>

                    <input type="number" name="quantity" class="form-control" min="1" placeholder="Enter quantity" required>
                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Book Cover Image URL
                    </label>
                    <input type="text" name="image" class="form-control" placeholder="Paste image URL here">
                </div>

                <button type="submit" 
                    class="btn btn-success">
                    Add Book
                </button>


                <a href="/inventory"
                   class="btn btn-secondary">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>
</body>
</html>