<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>My Borrowed Books</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
         html, body {
            height: 100%;
            margin:0;
        }
            
        body {
            background-image: url('images/userpage.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }
        .page-title{
            color:rgb(251, 0, 0);
            text-shadow: 1px 1px 4px rgb(0,0,0);
            -webkit-text-stroke: 1px black;
            
        }
    </style>

</head>


<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">

    <div class="container">
        <a class="navbar-brand fw-bold" href="/">📚 RP Library System</a>


        <div>
            <a href="/viewBooks" class="btn btn-outline-light me-2">
                View Books
            </a>

            <a href="/logout" class="btn btn-danger">
                Logout
            </a>
        </div>
    </div>
</nav>

<div class="container mt-4">
    <h2 class="mb-4 page-title">
        My Borrowed Books
    </h2>

    <% if(borrowedBooks.length === 0){ %>
        <div class="alert alert-info">
            You have not borrowed any books yet.
        </div>
    <% } else { %>

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">

                        <tr>
                            <th>Book Title</th>
                            <th>Author</th>
                            <th>Borrow Date</th>
                            <th>Due Date</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                    <% borrowedBooks.forEach(book => { %>
                        <tr>
                            <td>
                                <strong>
                                    <%= book.title %>
                                </strong>
                            </td>
                            <td>
                                <%= book.author %>
                            </td>
                            <td>
                                <%= new Date(book.borrowDate).toLocaleDateString('en-GB') %>
                            </td>

                            <td>
                                <%= new Date(book.dueDate).toLocaleDateString('en-GB') %>
                            </td>
                            <td>
                                <% if(book.status === "Borrowed"){ %>
                                    <span class="badge bg-warning text-dark">
                                        Borrowed
                                    </span>

                                <% } else { %>
                                    <span class="badge bg-success">
                                        Returned
                                    </span>
                                <% } %>
                            </td>

                            <td>
                                <% if(book.status === "Borrowed"){ %>
                                <form action="/returnBook/<%= book.borrowId %>"
                                      method="POST">

                                    <button class="btn btn-danger btn-sm">
                                        Return
                                    </button>
                                </form>

                                <% } else { %>

                                    <span class="text-muted">
                                        Completed
                                    </span>
                                <% } %>
                            </td>

                            <td>
                                <% if(book.status !== "Borrowed"){ %>

                                    <form action="/clearbooks/<%= book.borrowId %>" method="post">
                                        <button class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to clear this book?')">Delete</button>
                                    </form>

                                <% } else { %>

                                    <button class="btn btn-danger btn-sm" disabled>Delete</button>

                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <% } %>
</div>
</body>
</html>