<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manage Admins</title>
</head>
<body>
    <h1>Admin Accounts</h1>
    <!-- list of admin accounts, comes from SELECT query in app.js-->
    <table border="1">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Contact</th>
            </tr>
        </thead>
        <tbody>
            <!-- loop through each admin returned by SQL
              and display their information -->
            <% admins.forEach(function(admin) { %>
                <tr>
                    <td>
                        <%= admin.username %>
                        <!-- compare this row's id with current logged in user
                         if matched, row belongs to whoever's viewing the page-->
                        <% if (admin.id === currentUser.id) { %>
                            (You)
                        <% } %>
                    </td>
                    <td><%= admin.email %></td>
                    <td><%= admin.contact %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</body>
</html>