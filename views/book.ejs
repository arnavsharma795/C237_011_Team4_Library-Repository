<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= book.title %> - RP Library</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">📚 RP Library System</a>

        <div>
            <a href="/viewBooks" class="btn btn-outline-light me-2">
                View Books
            </a>
            <a href="/viewBorrowed" class="btn btn-outline-light me-2">
                My Books
            </a>
            <a href="/logout" class="btn btn-danger">
                Logout
            </a>
        </div>
    </div>
</nav>

<div class="container mt-5">
    <div class="card shadow">
        <div class="row g-0">
            <div class="col-md-4 text-center p-4">
                <% if(book.image){ %>

                    <img src="<%= book.image %>"
                         class="img-fluid rounded shadow" style="max-height:400px;">

                <% } else { %>

                    <img src="https://via.placeholder.com/300x400?text=No+Image"
                         class="img-fluid rounded">

                <% } %>
            </div>

            <div class="col-md-8">
                <div class="card-body">
                    <h1 class="card-title">
                        <%= book.title %>
                    </h1>

                    <p>
                        <strong>Author:</strong>
                        <%= book.author %>
                    </p>

                    <p>
                        <strong>Genre:</strong>

                        <span class="badge bg-info">
                            <%= book.genre %>
                        </span>
                    </p>

                    <p>
                        <strong>Description:</strong>
                    </p>

                    <p>
                        <%= book.description %>
                    </p>

                    <p>
                        <strong>
                            Available Copies:
                        </strong>

                        <% if(book.availableQuantity > 0){ %>

                            <span class="badge bg-success">
                                <%= book.availableQuantity %>
                            </span>

                        <% } else { %>

                            <span class="badge bg-danger">
                                Out of Stock
                            </span>

                        <% } %>
                    </p>


                    <% if(book.availableQuantity > 0){ %>


                    <form action="/borrowBook/<%= book.bookId %>"
                          method="POST">

                        <button class="btn btn-success">📖 Borrow Book</button>
                    </form>


                    <% } else { %>

                        <button class="btn btn-secondary" disabled>
                            Not Available
                        </button>


                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>