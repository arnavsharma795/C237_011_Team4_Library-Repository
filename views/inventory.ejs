<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RP Library Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">📚 RP Library System</a>

        <div class="ms-auto">
            <span class="text-white me-3">
                Admin: <%= user.name %>
            </span>

                <a href="/manageUsers" class="btn btn-warning me-2">
                Manage Accounts
                </a>

                <a href="/borrowRecords" class="btn btn-info me-2">
                Borrow Records
                </a>

            <a href="/logout" class="btn btn-outline-light">
                Logout
            </a>
        </div>
    </div>
</nav>


<div class="container mt-4">
    <!-- <style>
            html, body {
                height: 100%;
                margin:0;
            }
            
            body {
                background-image: url('images/adminbg.png');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
            }
        </style> -->

<div class="row mb-4">
    <!-- Total Books -->
    <div class="col-md-4">
        <div class="card text-center shadow border-primary">
            <div class="card-body">
                <h2 class="text-primary">
                    <%= books.length %>
                </h2>
                <p class="mb-0">
                    Total Books
                </p>
            </div>
        </div>
    </div>

    <!-- Available Copies -->
    <div class="col-md-4">
        <div class="card text-center shadow border-success">
            <div class="card-body">
                <h2 class="text-success">
                    <%= books.reduce((sum, book) => sum + book.availableQuantity, 0) %>
                </h2>
                <p class="mb-0">
                    Available Copies
                </p>
            </div>
        </div>
    </div>

    <!-- Borrowed Copies -->
    <div class="col-md-4">
        <div class="card text-center shadow border-danger">
            <div class="card-body">
                <h2 class="text-danger">
                    <%= books.reduce((sum, book) => sum + (book.quantity - book.availableQuantity), 0) %>
                </h2>
                <p class="mb-0">
                    Borrowed Copies
                </p>
            </div>
        </div>
    </div>
</div>

    <% if (books.length === 0) { %>

        <div class="alert alert-warning">
            No books found in the library.
        </div>

    <% } else { %>


    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Cover</th>
                            <th>Title</th>
                            <th>Author</th>
                            <th>Genre</th>
                            <th>Available</th>
                            <th>Borrowed</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>

                    <% books.forEach(book => { %>

                        <tr>
                            <td>
                                <%= book.bookId %>
                            </td>

                            <td>
                                <% if(book.image){ %>

                                    <img src="<%= book.image %>"
                                        width="70"
                                        height="90"
                                        class="rounded shadow"
                                        onerror="this.onerror=null; this.src='/images/no-image.png';">

                                <% } else { %>

                                    <img
                                        src="/images/no-image.png"
                                        width="70"
                                        height="90"
                                        class="rounded shadow mb-2">

                                <% } %>
                            </td>

                            <td>
                                <strong>
                                    <%= book.title %>
                                </strong>
                            </td>

                            <td>
                                <%= book.author %>
                            </td>

                            <td>
                                <span class="badge bg-info">
                                    <%= book.genre %>
                                </span>
                            </td>

                            <td>

                                <% if(book.availableQuantity > 0){ %>
                                    <span class="badge bg-success">
                                        <%= book.availableQuantity %>
                                    </span>
                                <% } else { %>
                                    <span class="badge bg-danger">
                                        Out of Stock
                                    </span>
                                <% } %>
                            </td>

                            <td>
                                <span class="badge bg-secondary">
                                    <%= book.quantity - book.availableQuantity %>
                                </span>
                            </td>

                            <td>
                                <a href="/editBook/<%= book.bookId %>"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <a href="/deleteBook/<%= book.bookId %>"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Delete this book?');">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <% } %>
</div>
</body>
</html>